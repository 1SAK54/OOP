<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ru.nsu.vorona.client.view.ConnectController"
      alignment="CENTER"
      spacing="14"
      style="-fx-background-color: #070c1a;">

    <padding>
        <Insets top="32" right="48" bottom="32" left="48"/>
    </padding>

    <Label text="Snake Online"
           style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>

    <TextField fx:id="nicknameField"
               promptText="Nickname"
               text="Player"
               maxWidth="260"/>

    <TextField fx:id="hostField"
               promptText="Host"
               text="localhost"
               maxWidth="260"/>

    <TextField fx:id="portField"
               promptText="Port"
               text="5555"
               maxWidth="260"/>

    <Button text="Connect"
            onAction="#onConnect"
            maxWidth="260"
            style="-fx-font-size: 16px; -fx-background-color: #ffc440; -fx-font-weight: bold;"/>

    <Label fx:id="errorLabel"
           text=""
           style="-fx-text-fill: #ff5c7a; -fx-font-size: 14px;"/>

</VBox>